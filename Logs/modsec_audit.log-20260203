a\x09\x09\x09\x09absolute positioning for sub-classes */\x0a\x09\x09\x09\x09position: relative;\x0a\x09\x09\x09\x09padding-top: 1em;\x0a                display: flex;\x0a\x09\x09\x09\x09flex-wrap: wrap;\x0a\x09\x09\x09}\x0a\x09\x09\x09.content-column-left {\x0a\x09\x09\x09\x09/* Value for IE/Win; will be overwritten for other browsers */\x0a\x09\x09\x09\x09width: 47%;\x0a\x09\x09\x09\x09padding: 15px 30px;\x0a\x09\x09\x09\x09margin-right: 30px;\x0a\x09\x09\x09\x09padding-bottom: 2em;\x0a\x09\x09\x09\x09margin-bottom: 1em;\x0a\x09\x09\x09\x09flex: 1;\x0a\x09\x09\x09}\x0a\x09\x09\x09.content-column-left hr {\x0a\x09\x09\x09\x09display: none;\x0a\x09\x09\x09}\x0a\x09\x09\x09.content-column-right {\x0a\x09\x09\x09\x09/* Values for IE/Win; will be overwritten for other browsers */\x0a\x09\x09\x09\x09width: 47%;\x0a\x09\x09\x09\x09padding: 15px 30px;\x0a\x09\x09\x09\x09padding-bottom: 2em;\x0a                margin-right: 30px;\x0a\x09\x09\x09\x09margin-bottom: 1em;\x0a\x09\x09\x09\x09flex: 1;\x0a\x09\x09\x09}\x0a\x09\x09\x09.content-columns>.content-column-left, .content-columns>.content-column-right {\x0a\x09\x09\x09\x09/* Non-IE/Win */\x0a                border: 1px solid #d2d2d2;\x0a\x09\x09\x09\x09border-radius: 3px;\x0a\x09\x09\x09\x09box-sizing: border-box;\x0a\x09\x09\x09}\x0a\x09\x09\x09.logos {\x0a\x09\x09\x09\x09text-align: left;\x0a\x09\x09\x09\x09margin-top: 2em;\x0a\x09\x09\x09}\x0a            .logos a img {\x0a                padding-right: 1.5em;\x0a                margin-right: 1.5em;\x0a                border-right: 1px solid #d2d2d2;\x0a            }\x0a\x09\x09\x09img {\x0a\x09\x09\x09\x09border: 2px solid #fff;\x0a\x09\x09\x09\x09padding: 2px;\x0a\x09\x09\x09\x09margin: 2px;\x0a\x09\x09\x09}\x0a\x09\x09\x09a:hover img {\x0a\x09\x09\x09\x09border: 2px solid #f50;\x0a\x09\x09\x09}\x0a\x09\x09\x09.footer {\x0a\x09\x09\x09    font-size: xx-small;\x0a                padding: 0 10em;\x0a\x09\x09\x09    padding-bottom: 5em;\x0a\x09\x09\x09}\x0a\x0a          